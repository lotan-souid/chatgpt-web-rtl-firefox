{
  "manifest_version": 3,
  "name": "ChatGPT RTL",
  "version": "0.1.1",
  "description": "Adds automatic right-to-left support for Hebrew conversations in ChatGPT.",
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-rtl@local",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "css": [
        "src/content.css"
      ],
      "js": [
        "src/direction.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
